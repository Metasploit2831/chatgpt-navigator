{
  "manifest_version": 3,
  "name": "ChatGPT Navigator",
  "version": "1.0",
  "description": "Turn AI chats into structured, navigable insights",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  },

  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
